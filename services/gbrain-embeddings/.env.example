# Copy to .env only when this host needs to override a default.

COMPOSE_PROJECT_NAME=gbrain-embeddings

# LiteLLM is pinned by repo digest. Update only after smoke validation passes.
LITELLM_IMAGE=docker.litellm.ai/berriai/litellm@sha256:3d80908e35230a0dfb58051ae4e2847371b2a327b44e105e79b8c4f67a65596c
LITELLM_MODEL_ALIAS=Qwen3-Embedding-8B
LITELLM_HOST_PORT=4000

# vLLM currently uses the locally built image from spark-vllm-docker.
VLLM_IMAGE=vllm-node:latest
VLLM_CONTAINER_NAME=gbrain-embeddings-vllm
VLLM_HOST_PORT=8888
VLLM_CONTAINER_PORT=8888
VLLM_MODEL_ID=Qwen/Qwen3-Embedding-8B
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEMORY_UTILIZATION=0.7
VLLM_TENSOR_PARALLEL=1

# Reuse the host Hugging Face cache by default.
HF_CACHE_DIR=/home/sailorjoe6/.cache/huggingface
HUGGING_FACE_HUB_TOKEN=
